# Environment
NODE_ENV=development

# API Configuration
API_PORT=3001
API_PREFIX=api

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orchestra_ai

# Redis
REDIS_URL=redis://localhost:6379

# JWT — CHANGE THIS in production (use: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

# OTEL (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
